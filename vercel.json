{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/share/:id",  "destination": "/share.html" },
    { "source": "/roster/:id", "destination": "/roster-share.html" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ]
}
