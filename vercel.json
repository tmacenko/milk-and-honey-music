{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/sheets.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/share/:id",  "destination": "/api/share-og?id=:id" },
    { "source": "/roster/:id", "destination": "/api/share-og?id=:id&kind=roster" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ]
}
